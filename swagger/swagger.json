    "/user/create": {
      "post": {
        "tags": [
          "User Management"
        ],
        "summary": "账号注册 (通用)",
        "description": "`X-Action-Token` 绑定了申请时的 `target`，请求体中的 `email` 或 `phone/tel` 需与该 `target` 一致。",
        "parameters": [
          {
            "name": "X-Action-Token",
            "in": "header",
            "required": true,
            "description": "(Required) 操作授权令牌，通过 `/user/action_token/anonymous` (mfaType: \"Register\") 获取",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "msg": "创建用户成功",
                  "data": {
                    "userId": 2
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "username": "user1",
                "user_password": "pwd",
                "email": "test@ex.com",
                "tel": "13800000000",
                "nickname": "Nick",
                "privilege": "User",
                "isMale": "true",
                "third_platform_name": "",
                "third_code": "",
                "third_verifyCode": ""
              }
            }
          }
        }
      }
