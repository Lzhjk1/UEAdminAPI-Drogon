          },
          {
            "name": "X-Action-Token",
            "in": "header",
            "required": true,
            "description": "(Required) 操作授权令牌，通过 `/user/action_token/anonymous` (mfaType: \"Login\") 获取",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
