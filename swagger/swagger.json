    "/user/login/pwd": {
      "get": {
        "tags": [
          "Login"
        ],
        "summary": "账号密码登录",
        "description": "",
        "parameters": [
          {
            "name": "userName",
            "in": "query",
            "required": true,
            "description": "用户名",
            "schema": {
              "type": "string"
