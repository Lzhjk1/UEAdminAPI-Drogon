    "/user/delete": {
      "delete": {
        "tags": [
          "User Management"
        ],
        "summary": "检查验证码",
        "description": "删除当前登录用户。需要先获取 `Action_DeleteUser` 类型的 ActionToken。用户的基本信息将被移动到 `user_deleted` 表中进行软删除，而第三方、GitLab 等关联信息将被彻底删除。",
        "parameters": [
          {
            "name": "target",
            "in": "query",
            "required": true,
            "description": "邮箱或手机号",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mfaCode",
            "in": "query",
