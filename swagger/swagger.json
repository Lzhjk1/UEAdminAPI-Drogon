          },
          {
            "name": "X-Action-Token",
            "in": "header",
            "required": true,
            "description": "(Required) 操作授权令牌，通过 `/user/action_token` (mfaType: \"ModifyUser\") 获取",
            "schema": {
              "type": "string"
